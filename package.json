{
  "name": "rbm-real-estate",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Monorepo configuration for RBM Realestate",
  "scripts": {
    "install:all": "npm install --prefix FrontEnd && npm install --prefix BackEnd",
    "build:frontend": "npm run build --prefix FrontEnd",
    "start:backend": "npm run start --prefix BackEnd",
    "dev:frontend": "npm run dev --prefix FrontEnd",
    "dev:backend": "npm run dev --prefix BackEnd",
    "build": "npm run build:frontend",
    "start": "NODE_ENV=production npm run start:backend",
    "vercel-build": "prisma generate --schema=BackEnd/prisma/schema.prisma && npm run build:frontend"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "helmet": "^8.0.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0"
  }
}
